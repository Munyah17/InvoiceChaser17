# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe Configuration
# Publishable key (safe to expose in frontend — used by Stripe.js)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key
# Secret key — NEVER commit this. Used only in server/functions.
STRIPE_SECRET_KEY=sk_live_your-secret-key
# Webhook signing secret — from Stripe Dashboard > Webhooks
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Paynow Configuration (Zimbabwe)
# Live keys - replace with your actual Paynow live credentials
PAYNOW_INTEGRATION_ID=your-live-integration-id
PAYNOW_INTEGRATION_KEY=your-live-integration-key

# Email Configuration (Resend)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=noreply@yourdomain.com
VITE_ADMIN_EMAIL=admin@yourdomain.com

# Cron Secret for Edge Functions
CRON_SECRET=your-random-secret-string

# App URL (used by the backend to build Paynow return/result URLs)
# In production set this to your deployed frontend URL, e.g. https://invoicechaser.netlify.app
VITE_APP_URL=http://localhost:4181
# Paynow result callback URL — must be publicly reachable (not localhost) for server-side confirmation
# In production: https://your-backend.com/api/paynow-result  or the Netlify function URL
PAYNOW_RESULT_URL=http://localhost:3001/api/paynow-result
